// SkillProof Phase 1 schema — mirrors tech spec §5 conventions:
// UUID PKs, createdAt/updatedAt everywhere, soft deletes on user-facing entities.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CANDIDATE
  EMPLOYER_ADMIN
  EMPLOYER_MEMBER
  PLATFORM_ADMIN
}

enum IdentityProvider {
  PHONE
  GOOGLE
  GITHUB
}

enum SkillLevel {
  L1
  L2
  L3
  L4
}

/**
 * How a Badge's level was demonstrated. Precedence (see
 * BadgeResolverService, apps/api/src/modules/badges/badge-resolver.service.ts)
 * is DISCUSSION > TEST for the same skill+level: a reviewer watching a
 * candidate reason through a live conversation is stronger evidence than a
 * multiple-choice score. Every Badge is a permanent, unrevoked record of its
 * own issuance regardless of precedence — this enum only affects which
 * Badge a resolver picks as "the" current one for a given skill+level; nine
 * out of ten it never even applies since most skill+level pairs will only
 * ever have one format available.
 */
enum BadgeVerificationMethod {
  TEST
  DISCUSSION
}

enum ClaimStatus {
  UNVERIFIED
  VERIFIED
  EXPIRED
}

enum AttemptStatus {
  CREATED
  IN_PROGRESS
  SUBMITTED
  GRADING
  GRADED
  FAILED_INTEGRITY
}

// ---------- Integrity monitoring (spec: lightweight, detect-and-record) ----------
// Signals only — never treated as proof. See IntegrityEvent doc comment.

enum IntegrityEventType {
  TAB_BLUR
  TAB_FOCUS
  PASTE_ATTEMPT
  COPY_ATTEMPT
  FULLSCREEN_EXIT
  RAPID_ANSWER
  RIGHT_CLICK
  /**
   * Browser detected the PrintScreen key specifically. Partial signal only —
   * OS-level screenshot tools (Win+Shift+S Snipping Tool, a second device
   * photographing the screen, etc.) fire no browser event at all and are not
   * detectable this way. Do not treat this as screenshot prevention.
   */
  PRINT_SCREEN
}

enum IntegrityStatus {
  CLEAN
  FLAGGED
  REVIEW
  INVALIDATED
}

/**
 * An admin's decision on a FLAGGED attempt — the only thing that can invalidate an attempt/badge.
 */
enum ReviewOutcome {
  APPROVED
  INVALIDATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum JobStatus {
  DRAFT
  LIVE
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  REVIEWED
  SHORTLISTED
  REJECTED
  WITHDRAWN
}

/**
 * Hiring-pipeline stage for a ShortlistEntry. Only SHORTLISTED is set by
 * anything today (ShortlistService.add always creates at the default) — the
 * rest exist now so the pipeline feature can PATCH an entry's stage without
 * a second migration. Distinct from ApplicationStatus.SHORTLISTED: that's a
 * per-application review status an employer sets on a candidate who applied
 * to a specific job; this is membership in the org's own shortlist
 * collection, which a candidate can join without ever applying (e.g. from
 * candidate search) and which will drive the pipeline UI next.
 */
enum ShortlistStage {
  SHORTLISTED
  INVITED
  INTERVIEWING
  OFFER
  HIRED
  DECLINED
  REJECTED
  CLOSED
}

/**
 * The candidate's own write on an OFFER-stage entry — deliberately separate
 * from ShortlistEntry.stage (which the employer alone advances to HIRED /
 * CLOSED). See ShortlistEntry.candidateResponse's doc comment for the
 * two-write rationale: these can legitimately disagree and neither
 * overwrites the other.
 */
enum CandidateOfferResponse {
  ACCEPTED
  DECLINED
  NEGOTIATING
}

enum InterviewRoundStatus {
  SCHEDULED
  COMPLETED
  PASSED
  FAILED
}

enum NotificationType {
  APPLICATION_CONFIRMATION
  APPLICATION_STATUS
  MATCH_DIGEST
  /**
   * Candidate: SHORTLISTED → INVITED.
   */
  PIPELINE_INVITE
  /**
   * Employer: candidate accepted or declined an invite.
   */
  PIPELINE_INVITE_RESPONSE
  /**
   * Candidate: a new InterviewRound was added.
   */
  PIPELINE_ROUND_SCHEDULED
  /**
   * Candidate: INTERVIEWING → OFFER.
   */
  PIPELINE_OFFER
  /**
   * Employer: candidate set candidateResponse on an offer.
   */
  PIPELINE_OFFER_RESPONSE
  /**
   * Candidate: → REJECTED.
   */
  PIPELINE_REJECTED
}

enum NotificationChannel {
  EMAIL
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

// ---------- External credentials (Credly-first, URL-verified) ----------

enum CredentialIssuer {
  CREDLY
  AWS
  GOOGLE
  AZURE
  NVIDIA
  DATABRICKS
  IBM
  OTHER
}

enum CredentialVerificationState {
  PENDING
  VERIFIED
  FAILED
}

/**
 * Advisory-only signal comparing the badge holder's name (when the issuer
 * exposes one) against the candidate's profile fullName. Never affects
 * verificationState or the apply-gate — see ExternalCredential.nameMatchState.
 */
enum NameMatchState {
  MATCH
  MISMATCH
  UNCHECKED
}

model User {
  id           String    @id @default(uuid())
  phone        String?   @unique
  email        String?   @unique
  passwordHash String?
  role         Role      @default(CANDIDATE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  profile               CandidateProfile?
  attempts              Attempt[]
  badges                Badge[]
  refreshTokens         RefreshToken[]
  orgMembership         OrgMember?
  notifications         Notification[]
  reviewedAttempts      Attempt[]           @relation("AttemptReviewedBy")
  identities            Identity[]
  assessmentSessions    AssessmentSession[]
  reviewedClaimVerdicts ClaimVerdict[]      @relation("ClaimVerdictReviewedBy")
  decidedSessions       AssessmentSession[] @relation("SessionDecidedBy")
  shortlistEntriesAdded ShortlistEntry[]
}

// ---------- Multi-provider auth (phone OTP, Google, GitHub) ----------

/**
 * One row per (provider, providerId) a user has signed in with. providerId is
 * the provider's own stable subject identifier (Google `sub`, GitHub numeric
 * user id, or the phone number for the PHONE provider) — never the email,
 * since emails can change or be reassigned by the provider. email/emailVerified
 * are just what that provider reported at the time of the most recent link;
 * they drive the auto-link-by-verified-email policy in AuthService and are
 * not treated as a login key.
 */
model Identity {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  provider      IdentityProvider
  providerId    String
  email         String?
  emailVerified Boolean          @default(false)
  createdAt     DateTime         @default(now())

  @@unique([provider, providerId])
  @@index([userId])
}

// ---------- Employer accounts (spec section: employer side, step 3a) ----------

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          OrgMember[]
  jobs             Job[]
  shortlistEntries ShortlistEntry[]
}

model OrgMember {
  id             String       @id @default(uuid())
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

/**
 * Structured job-title dropdown, separate from the free-text `headline`.
 * Predefined AI/ML role categories the candidate self-selects, plus OTHER
 * with `roleTitleOther` as its free-text fallback. Display and filter only —
 * see CandidateRoleTitle's own doc comment for why this must never reach
 * scoring.ts.
 */
enum CandidateRoleTitle {
  AI_ENGINEER
  ML_ENGINEER
  PROMPT_ENGINEER
  DATA_SCIENTIST
  MLOPS_ENGINEER
  NLP_ENGINEER
  COMPUTER_VISION_ENGINEER
  RESEARCH_ENGINEER
  DATA_ENGINEER
  AI_PRODUCT_MANAGER
  /**
   * Free-text fallback — see CandidateProfile.roleTitleOther.
   */
  OTHER
}

model CandidateProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id])
  fullName           String?
  headline           String?
  location           String?
  yearsOfExp         Float?
  githubUrl          String?
  linkedinUrl        String?
  resumeS3Key        String?
  /**
   * Storage key/filename within UPLOAD_DIR, same convention as
   * resumeS3Key (see that field's doc comment on the "S3" naming being
   * legacy — still local disk for now). Never exposed to clients directly;
   * GET /profiles/me and GET /users/me expose a derived `hasPhoto`
   * boolean instead, and the actual bytes are only ever served through
   * the authenticated GET /profiles/:id/photo proxy endpoint — never a
   * public URL or presigned link. See ProfilesService for the
   * upload/serve/delete logic and its owner-only Phase-1 access check.
   */
  photoKey           String?
  completeness       Int       @default(0)
  emailNotifications Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  /**
   * Structured role/title dropdown (roleTitleOther holds the free-text value
   * when roleTitle is OTHER). Candidate-set directly, or accepted from an
   * AI resume-parse suggestion only after the candidate confirms it in the
   * review UI — never auto-applied. Display and employer search/filter
   * only. NEVER read this in scoring.ts / matching.service.ts — matching is
   * driven solely by verified SkillClaims and verified ExternalCredentials
   * (see those models' own "never feeds match scoring" comments); this
   * field carries no verification and must not influence match scores.
   */
  roleTitle      CandidateRoleTitle?
  roleTitleOther String?

  skillClaims         SkillClaim[]
  applications        Application[]
  externalCredentials ExternalCredential[]
  shortlistEntries    ShortlistEntry[]
}

// ---------- Taxonomy (spec section 4.3) ----------

model Domain {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0)
  skills    Skill[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id          String   @id @default(uuid())
  domainId    String
  domain      Domain   @relation(fields: [domainId], references: [id])
  name        String
  aliases     String[]
  // One-line summary shown on the skill-grouped assessments catalog card
  // (see AssessmentsService.getCatalog). Nullable — most seeded skills
  // predate this field and have no copy written yet; the card just omits
  // the line rather than showing a placeholder.
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  claims      SkillClaim[]
  assessments Assessment[]
  jobSkills   JobSkill[]
  badges      Badge[]

  @@unique([domainId, name])
}

model SkillClaim {
  id        String           @id @default(uuid())
  profileId String
  profile   CandidateProfile @relation(fields: [profileId], references: [id])
  skillId   String
  skill     Skill            @relation(fields: [skillId], references: [id])
  level     SkillLevel       @default(L1)
  status    ClaimStatus      @default(UNVERIFIED)
  badgeId   String?          @unique
  badge     Badge?           @relation(fields: [badgeId], references: [id])
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([profileId, skillId])
}

/**
 * A candidate-submitted, externally-issued credential (Credly badge, etc.),
 * kept entirely separate from the SkillClaim/Badge system: it never maps to
 * our skill taxonomy and never feeds match scoring (scoring.ts). It only
 * ever unlocks the apply-gate as an alternative to a verified SkillClaim —
 * see CandidateJobsService.assertHasVerifiedBadge.
 * name/issuer/externalId/issuedAt/expiresAt/rawMetadata are populated by
 * CredlyVerificationService from the fetched public badge data — never
 * client-supplied — and stay null until a verification attempt succeeds.
 * issuer defaults to OTHER (the "unidentified" state) until a successful
 * fetch identifies the real issuing org.
 * nameMatchState is a separate, advisory-only signal (see NameMatchState) —
 * it never influences verificationState or the apply-gate. It's UNCHECKED
 * whenever the issuer's data has no holder name to compare (the common case
 * today: Credly's public OBI assertion only exposes a hashed recipient
 * email, not a plaintext name) or the candidate has no profile fullName yet.
 */
model ExternalCredential {
  id                String                      @id @default(uuid())
  profileId         String
  profile           CandidateProfile            @relation(fields: [profileId], references: [id])
  issuer            CredentialIssuer            @default(OTHER)
  name              String?
  credentialUrl     String
  verificationState CredentialVerificationState @default(PENDING)
  nameMatchState    NameMatchState              @default(UNCHECKED)
  verifiedAt        DateTime?
  externalId        String?
  issuedAt          DateTime?
  expiresAt         DateTime?
  rawMetadata       Json?
  createdAt         DateTime                    @default(now())

  @@unique([profileId, credentialUrl])
  @@index([profileId])
}

// ---------- Job postings (employer side, step 3b) ----------

model Job {
  id             String         @id @default(uuid())
  orgId          String
  organization   Organization   @relation(fields: [orgId], references: [id])
  title          String
  description    String
  employmentType EmploymentType
  location       String?
  remote         Boolean        @default(false)
  experienceMin  Int?
  experienceMax  Int?
  salaryMin      Int?
  salaryMax      Int?
  status         JobStatus      @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  skills           JobSkill[]
  applications     Application[]
  shortlistEntries ShortlistEntry[]

  @@index([orgId])
}

model JobSkill {
  id            String     @id @default(uuid())
  jobId         String
  job           Job        @relation(fields: [jobId], references: [id])
  skillId       String
  skill         Skill      @relation(fields: [skillId], references: [id])
  requiredLevel SkillLevel @default(L1)
  isRequired    Boolean    @default(true)

  @@unique([jobId, skillId])
}

// ---------- Applications (candidate side, step 3d) ----------

model Application {
  id                 String            @id @default(uuid())
  candidateProfileId String
  candidateProfile   CandidateProfile  @relation(fields: [candidateProfileId], references: [id])
  jobId              String
  job                Job               @relation(fields: [jobId], references: [id])
  status             ApplicationStatus @default(APPLIED)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([candidateProfileId, jobId])
  @@index([jobId])
}

// ---------- Shortlist (employer portal — hiring-pipeline entry point) ----------

/**
 * One candidate an employer org has collected for hiring-pipeline
 * consideration. jobId is optional: entries created from a job's applicant
 * list or its match results are tied to that job, but entries created from
 * the org-wide candidate search aren't about any one opening, so jobId is
 * null there. @@unique enforces "not shortlisted twice for the same job"
 * (or twice generally, when jobId is null) at the DB level for any given
 * non-null jobId; ShortlistService.add is the actual idempotency guarantee
 * for callers (see its own doc comment) since Postgres treats NULL as
 * distinct in unique constraints, so the null-jobId case isn't fully
 * DB-enforced.
 */
model ShortlistEntry {
  id               String           @id @default(uuid())
  orgId            String
  organization     Organization     @relation(fields: [orgId], references: [id])
  candidateId      String
  candidateProfile CandidateProfile @relation(fields: [candidateId], references: [id])
  jobId            String?
  job              Job?             @relation(fields: [jobId], references: [id])
  addedByUserId    String
  addedByUser      User             @relation(fields: [addedByUserId], references: [id])
  stage            ShortlistStage   @default(SHORTLISTED)
  note             String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  /**
   * Employer-authored, sent with the SHORTLISTED→INVITED transition. Candidate-visible — it's addressed to them.
   */
  inviteMessage String?
  /**
   * Employer-authored, sent with the →REJECTED transition. Deliberately
   * NOT exposed on GET /interviews/mine — same "employer-only" treatment as
   * InterviewRound.note, for the same reason (an internal reason isn't
   * necessarily something to hand a rejected candidate verbatim).
   */
  rejectReason  String?

  /**
   * The candidate's own write on an OFFER-stage entry — see
   * CandidateOfferResponse's doc comment. Settable only while stage is
   * still OFFER (ShortlistPipelineService/InterviewsService both enforce
   * this); once the employer's outcome write moves stage to HIRED/CLOSED,
   * this value is frozen as the historical record of what the candidate
   * said at the time, which may or may not match the outcome. Never
   * overwritten by, and never overwrites, `stage`.
   */
  candidateResponse CandidateOfferResponse?

  rounds InterviewRound[]

  @@unique([orgId, candidateId, jobId])
  @@index([orgId, stage])
  @@index([jobId])
  @@index([candidateId])
}

/**
 * One interview round on a ShortlistEntry, employer-driven and repeatable —
 * there is no fixed count; the employer adds the next round when ready.
 * roundNumber is server-assigned (see ShortlistPipelineService.addRound),
 * never client-supplied, so ordering can't be gamed or gapped.
 */
model InterviewRound {
  id               String               @id @default(uuid())
  shortlistEntryId String
  shortlistEntry   ShortlistEntry       @relation(fields: [shortlistEntryId], references: [id])
  roundNumber      Int
  status           InterviewRoundStatus @default(SCHEDULED)
  /**
   * Zoom/Meet link, phone number, "we'll email you" — free text the candidate reads, not validated as a URL.
   */
  channel          String?
  scheduledAt      DateTime?
  /**
   * Employer-only — never returned by GET /interviews/mine.
   */
  note             String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([shortlistEntryId, roundNumber])
  @@index([shortlistEntryId])
}

// ---------- Notifications (spec section: email, step 3e) ----------

model Notification {
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  type      NotificationType
  channel   NotificationChannel @default(EMAIL)
  subject   String
  body      String
  status    NotificationStatus  @default(QUEUED)
  // Job ids this notification already covered — only populated for
  // MATCH_DIGEST, so the daily digest job can exclude jobs a candidate has
  // already been told about instead of re-sending the same match forever.
  jobIds    String[]            @default([])
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId])
}

// ---------- Assessments (spec section 4.4) ----------

model Assessment {
  id                  String     @id @default(uuid())
  skillId             String
  skill               Skill      @relation(fields: [skillId], references: [id])
  title               String
  targetLevel         SkillLevel
  durationMins        Int        @default(30)
  // Server-enforced deadline = Attempt.startedAt + durationMins. This is
  // also the field the task brief calls "timeLimitMinutes" — durationMins
  // already existed and means the same thing, so it's reused rather than
  // duplicated (see AssessmentsService.deadlineFor).
  passThreshold       Int        @default(70)
  // Also existing — a 0-100 percentage compared against scorePercent in
  // gradeAttempt(), not a separate 0-1 fraction field.
  questionsPerAttempt Int        @default(20)
  isPremium           Boolean    @default(false)
  isLive              Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  questions Question[]
  attempts  Attempt[]
}

model Question {
  id           String     @id @default(uuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  type         String     @default("MCQ") // MCQ | CODING | PROMPT_TASK
  body         Json // question text + options (safe to send to client)
  correct      Json // answers/rubric — NEVER send to client
  difficulty   Int        @default(2)
  isLive       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  answers          AttemptAnswer[]
  servedTimestamps QuestionServedAt[]
}

model Attempt {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  assessmentId String
  assessment   Assessment    @relation(fields: [assessmentId], references: [id])
  status       AttemptStatus @default(CREATED)
  startedAt    DateTime?
  submittedAt  DateTime?
  scorePercent Int?
  passed       Boolean?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Integrity monitoring — aggregate counters kept in sync with IntegrityEvent
  // rows by AssessmentsService (see addIntegrityEvent); never written by the client.
  integrityFlagCount Int             @default(0)
  integrityStatus    IntegrityStatus @default(CLEAN)

  // Admin review of a FLAGGED attempt (AdminService.reviewAttempt) — the only
  // path that can move an attempt to INVALIDATED and revoke its badge.
  // Null until an admin actually reviews it.
  reviewOutcome    ReviewOutcome?
  reviewNote       String?
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewedByUser   User?          @relation("AttemptReviewedBy", fields: [reviewedByUserId], references: [id])

  answers         AttemptAnswer[]
  badge           Badge?
  integrityEvents IntegrityEvent[]
  questionsServed QuestionServedAt[]
}

/**
 * One detected integrity signal for an attempt — a tab blur, a paste, an
 * implausibly-fast answer, etc. This is an audit trail, not a verdict: each
 * row records what was observed, never a conclusion. `metadata` is a free-form
 * JSON bag (e.g. { questionId, elapsedMs } for RAPID_ANSWER) so new event
 * types — including a future webcam/proctoring tier — can attach whatever
 * detail they need without a schema change.
 */
model IntegrityEvent {
  id        String             @id @default(uuid())
  attemptId String
  attempt   Attempt            @relation(fields: [attemptId], references: [id])
  type      IntegrityEventType
  metadata  Json?
  createdAt DateTime           @default(now())

  @@index([attemptId])
}

/**
 * Server-recorded "this question was served to the candidate at this time"
 * — one row per (attempt, question), created when the question set is first
 * fetched and refreshed (bumped to "now") for every still-unanswered question
 * whenever any other answer lands. That refresh is what makes RAPID_ANSWER a
 * genuine per-question signal instead of one dominated by time already spent
 * on earlier questions — see AssessmentsService.checkRapidAnswer /
 * refreshServedTimestamps. Never written from anything client-reported.
 */
model QuestionServedAt {
  id         String   @id @default(uuid())
  attemptId  String
  attempt    Attempt  @relation(fields: [attemptId], references: [id])
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  servedAt   DateTime @default(now())

  @@unique([attemptId, questionId])
}

model AttemptAnswer {
  id         String   @id @default(uuid())
  attemptId  String
  attempt    Attempt  @relation(fields: [attemptId], references: [id])
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  answer     Json
  isCorrect  Boolean?
  createdAt  DateTime @default(now())

  @@unique([attemptId, questionId])
}

/**
 * Issued from exactly one of two sources, never both — MCQ attempts
 * (AssessmentsService.issueBadge) or reviewed conversational sessions
 * (ReviewService.issueBadge, only via POST /assessment-sessions/:id/decision
 * ISSUE). Both attemptId and sessionId are nullable rather than a shared
 * required FK because the two source models are unrelated; each issuance
 * path only ever sets its own column. No DB-level "exactly one" constraint —
 * enforced by there being exactly two controlled call sites, same as the
 * rest of this schema's soft invariants.
 * Every passing attempt/session mints its own Badge row — this table is a
 * permanent, immutable log of evidence, never pruned or overwritten. skillId
 * is stored directly (not just derivable via attempt.assessment.skillId)
 * because session-issued badges have no other path to their skill at all —
 * see BadgeResolverService's doc comment for why precedence has to be
 * resolved at read time across potentially several Badge rows for the same
 * user+skill+level, rather than by mutating this table.
 */
model Badge {
  id         String                  @id @default(uuid())
  userId     String
  user       User                    @relation(fields: [userId], references: [id])
  skillId    String
  skill      Skill                   @relation(fields: [skillId], references: [id])
  attemptId  String?                 @unique
  attempt    Attempt?                @relation(fields: [attemptId], references: [id])
  sessionId  String?                 @unique
  session    AssessmentSession?      @relation(fields: [sessionId], references: [id])
  verifiedBy BadgeVerificationMethod
  verifyHash String                  @unique
  level      SkillLevel
  issuedAt   DateTime                @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  skillClaim SkillClaim?

  @@index([userId, skillId, level])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ---------- Conversational AI assessor sessions (RAG Systems L2, text-based) ----------

enum AssessmentSessionStatus {
  IN_PROGRESS
  AWAITING_SCORING
  AWAITING_REVIEW
  EXPIRED
  // Terminal decision outcomes — set only by ReviewService.decide, and only
  // once every ClaimVerdict has a reviewerVerdict. ISSUE also mints a Badge
  // (see ReviewService.issueBadge); REJECT never does.
  ISSUED
  REJECTED
  // Set by a candidate disputing a claim on an already-decided (ISSUED or
  // REJECTED) session (see AssessmentSessionsService.disputeClaim). Reappears
  // in the admin review queue flagged as disputed. Resolved by
  // AssessmentSessionsService.resolveDispute, which reverts the session to
  // AssessmentSession.preDisputeStatus once no disputes remain unresolved.
  DISPUTED
}

/**
 * The six claims in the RAG Systems L2 rubric (see rag-systems-l2.rubric.ts
 * in the assessment-sessions module for the probe content per claim). Order
 * here is cosmetic — CLAIM_ORDER in that file is what actually drives the
 * ladder walk.
 */
enum RagL2Claim {
  CHUNKING
  DIAGNOSIS
  RERANKING
  CORPUS_CHANGE
  EVALUATION
  COST
}

enum ProbeRung {
  OPENING
  FOLLOWUP
  CONSTRAINT
}

enum SessionTurnRole {
  CANDIDATE
  ASSESSOR
}

/**
 * One live conversational assessment. ladderState is the single source of
 * truth for "where the ladder walk currently is" (see AssessorService's
 * LadderState type) — a resumed session re-reads it and re-asks exactly the
 * probe that was outstanding, rather than restarting. pinnedBrief is a
 * denormalized copy of the scenario text handed to the candidate at session
 * start, kept separate from the turn transcript so the client can keep it
 * pinned on screen without re-parsing the opening turn.
 */
model AssessmentSession {
  id               String                   @id @default(uuid())
  userId           String
  user             User                     @relation(fields: [userId], references: [id])
  status           AssessmentSessionStatus  @default(IN_PROGRESS)
  pinnedBrief      String
  ladderState      Json
  // Copied onto every ClaimVerdict scored from this session (see
  // ScoringService) — RUBRIC_VERSION in rag-systems-l2.rubric.ts is the
  // single source of truth; this just pins which version a given session
  // was run/scored against, since the rubric text itself is not versioned
  // in the DB.
  rubricVersion    String                   @default("rag-systems-l2-r2")
  startedAt        DateTime                 @default(now())
  lastActivityAt   DateTime                 @default(now())
  expiresAt        DateTime
  // Set once ScoringService.scoreSession finishes successfully (status ->
  // AWAITING_REVIEW). scoringError is populated instead when scoring fails,
  // so a broken session stays visibly AWAITING_SCORING and retryable via
  // POST /assessment-sessions/:id/score rather than vanishing silently.
  scoredAt         DateTime?
  scoringError     String?
  // Set once by ReviewService.decide (ISSUED or REJECTED) — never touched
  // again afterward. decisionNote carries the REJECT reason, or an optional
  // note on ISSUE.
  decidedAt        DateTime?
  decidedByUserId  String?
  decidedByUser    User?                    @relation("SessionDecidedBy", fields: [decidedByUserId], references: [id])
  decisionNote     String?
  // The status just before a dispute flipped this session to DISPUTED —
  // cleared once resolveDispute reverts to it (see
  // AssessmentSessionsService.disputeClaim/resolveDispute). Never touched by
  // anything but those two methods; decidedAt is never touched by disputing
  // either, so the original decision timestamp — and the retake cooldown
  // computed from it — survives a dispute untouched.
  preDisputeStatus AssessmentSessionStatus?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  turns             SessionTurn[]
  interruptions     SessionInterruption[]
  claimVerdicts     ClaimVerdict[]
  disputes          ClaimDispute[]
  liveClaimFeedback LiveClaimFeedback[]
  badge             Badge?

  @@index([userId])
}

/**
 * One message in the conversation. claimId/probeRung record which ladder
 * position this turn targets (the probe an ASSESSOR turn is asking, or the
 * probe a CANDIDATE turn is answering) — both null for reflection-stage
 * turns, which aren't scored against any claim. superseded marks a turn
 * that was re-asked after a resume (see AssessmentSessionsService.resume) —
 * superseded turns are excluded from the conversation history sent to the
 * model and from the candidate-facing transcript, but kept for audit.
 */
model SessionTurn {
  id         String            @id @default(uuid())
  sessionId  String
  session    AssessmentSession @relation(fields: [sessionId], references: [id])
  role       SessionTurnRole
  content    String
  claimId    RagL2Claim?
  probeRung  ProbeRung?
  superseded Boolean           @default(false)
  createdAt  DateTime          @default(now())

  // Optional, candidate-turn-only composition telemetry (paste/timing/focus)
  // — see TurnSignals' own doc comment. Kept as a separate related model
  // rather than columns here so a plain `sessionTurn.findMany()` (exactly
  // what ScoringService uses) never brings this data along; it only
  // surfaces where something explicitly does `include: { signals: true }`,
  // which the scoring path never does.
  signals TurnSignals?

  @@index([sessionId])
}

/**
 * Composition telemetry captured client-side for one CANDIDATE turn —
 * paste activity, timing, and window-focus behavior while writing that
 * answer. Neutral context for the human reviewer only (see ReviewService's
 * signal-summary helpers): never a score, never a flag, never read by
 * ScoringService's extractor/adjudicator. Every field is nullable — older
 * sessions predate this table entirely (no row at all), and any client that
 * fails to report a given metric (or all of them) must not break turn
 * submission; POST .../turns persists whatever subset arrives, or no row if
 * the client sent nothing.
 */
model TurnSignals {
  id            String      @id @default(uuid())
  sessionTurnId String      @unique
  sessionTurn   SessionTurn @relation(fields: [sessionTurnId], references: [id])

  // Paste activity while composing this turn.
  pasteCount        Int?
  pastedCharCount   Int?
  largestPasteChars Int?

  // Timing: assessor turn rendered -> first keystroke -> send.
  timeToFirstKeystrokeMs Int?
  compositionDurationMs  Int?
  charCount              Int?
  // Derived (charCount / 5 chars-per-word ÷ compositionDurationMs), stored
  // rather than recomputed so the reviewer view and any later analysis agree
  // on the exact same number the client observed.
  effectiveWpm           Float?

  // Window focus while this turn had content or focus.
  blurCount      Int?
  blurDurationMs Int?

  createdAt DateTime @default(now())
}

/**
 * Audit trail for a session going EXPIRED (idle timeout) and, once resumed,
 * how that resume was handled. fragmentTurnId points at the ASSESSOR turn
 * that was outstanding when the session broke — the one marked superseded
 * and re-asked fresh on resume (see resume() in the service).
 */
model SessionInterruption {
  id             String            @id @default(uuid())
  sessionId      String
  session        AssessmentSession @relation(fields: [sessionId], references: [id])
  occurredAt     DateTime          @default(now())
  resumedAt      DateTime?
  fragmentTurnId String?
  createdAt      DateTime          @default(now())

  @@index([sessionId])
}

enum Verdict {
  DEMONSTRATED
  PARTIAL
  NOT_EVIDENCED
  ABSTAIN
  // Reviewer-only — the model never produces this (ScoringService's own
  // record_verdict tool schema is still restricted to the four values
  // above). Means the assessor failed to elicit evidence on this claim at
  // all — a verdict about the session/assessor, not the candidate. Blocks
  // ISSUE for the gating claims (see ReviewService's level rule) in favor
  // of offering a re-take, never a rejection.
  INSUFFICIENT_PROBING
}

/**
 * The AI-scored outcome for one claim in one session (see ScoringService).
 * The model.../reviewer... column split is deliberate and permanent: the
 * model's original verdict/bandBoundary/reason/confidence are written once
 * at scoring time and never touched again — verdict/bandBoundary/reason are
 * the "working" columns a human reviewer can override via reviewerVerdict
 * etc. The gap between the model columns and the reviewer columns across
 * enough sessions is the calibration dataset that eventually justifies
 * auto-issue; overwriting the model columns on review would destroy that
 * signal. modelConfidence is captured for the same calibration purpose and
 * deliberately unused elsewhere — triage keys off bandBoundary/ABSTAIN, not
 * confidence (near-constant in harness runs, not a real judgment signal).
 * reviewerVerdict/reviewerId/reviewerNote/reviewedAt are write-once — see
 * ReviewService.reviewClaim's 409 on a second attempt; a mistaken review is
 * corrected by a second reviewer's note later, never by overwriting.
 */
model ClaimVerdict {
  id            String            @id @default(uuid())
  sessionId     String
  session       AssessmentSession @relation(fields: [sessionId], references: [id])
  claimId       RagL2Claim
  rubricVersion String

  // Working columns — start identical to the model's output, but this is
  // the pair a human reviewer's override should land in eventually (no
  // reviewer-write path exists yet; that's a future admin action).
  verdict      Verdict
  bandBoundary Boolean
  reason       String

  // Immutable copies of pass 2's original output — never overwritten.
  modelVerdict      Verdict
  modelBandBoundary Boolean
  modelReason       String
  modelConfidence   Float

  // Extracted evidence (pass 1 output, filtered to this claim) that pass 2
  // adjudicated from — [{quote, probeContext}], quotes verbatim from the
  // candidate's own turns. Kept for reviewer audit without re-reading the
  // whole transcript.
  spans Json

  reviewerVerdict Verdict?
  reviewerId      String?
  reviewerUser    User?     @relation("ClaimVerdictReviewedBy", fields: [reviewerId], references: [id])
  reviewerNote    String?
  reviewedAt      DateTime?

  createdAt DateTime @default(now())

  @@unique([sessionId, claimId])
  @@index([sessionId])
}

/**
 * A candidate's dispute of one claim's reviewed verdict, filed from the
 * results page (see AssessmentSessionsService.disputeClaim) — only possible
 * once a session is decided (ISSUED/REJECTED), and only once per claim
 * (@@unique below — a second attempt on the same claim 409s). Filing a
 * dispute flips the session to DISPUTED, which folds it back into the admin
 * review queue as a flagged case (see ScoringService.getReviewQueue).
 * resolvedAt/resolution are nullable and unused by any endpoint yet — they
 * exist for a future admin resolution action, not wired up in this pass.
 */
model ClaimDispute {
  id          String            @id @default(uuid())
  sessionId   String
  session     AssessmentSession @relation(fields: [sessionId], references: [id])
  claimId     RagL2Claim
  candidateId String
  body        String
  createdAt   DateTime          @default(now())
  resolvedAt  DateTime?
  resolution  String?
  // Set together with resolvedAt/resolution by
  // AssessmentSessionsService.resolveDispute — null until resolved. An
  // upheld dispute (the reviewer's verdict was wrong) exempts the session
  // from the retake cooldown once reverted to REJECTED, the same way
  // Verdict.INSUFFICIENT_PROBING does: it's a fault of the process, not the
  // candidate. See isRetakeCooldownExempt.
  upheld      Boolean?

  @@unique([sessionId, claimId])
  @@index([sessionId])
}

/**
 * Informal, candidate-facing coaching note for one completed claim — generated once that
 * claim's ladder walk finishes (see AssessmentSessionsService.postTurn). Deliberately distinct
 * from ClaimVerdict/ScoringService: this is shown live, is never the official scored verdict,
 * and is never read by ScoringService or ReviewService. helpfulVote is upsertable (a low-stakes
 * UI toggle), not write-once like ClaimDispute.
 */
model LiveClaimFeedback {
  id           String            @id @default(uuid())
  sessionId    String
  session      AssessmentSession @relation(fields: [sessionId], references: [id])
  claimId      RagL2Claim
  verdictLabel String
  // Drives the verdict chip's color/icon — a structured field, not
  // something the UI infers from verdictLabel text, so the chip can never
  // contradict the label (see LiveFeedbackService's tool schema, which
  // requires the model to set this consistently with the label/gaps it
  // wrote in the same call). Nullable because it was added after
  // verdictLabel existed; the migration backfills every pre-existing row
  // (inferred from label text, defaulting to MIXED) rather than leaving
  // real gaps, but stays nullable in case a future row somehow lands
  // without one.
  verdictTone  LiveFeedbackTone?
  summary      String
  strengths    Json
  gaps         Json
  helpfulVote  Boolean?
  votedAt      DateTime?
  createdAt    DateTime          @default(now())

  @@unique([sessionId, claimId])
  @@index([sessionId])
}

enum LiveFeedbackTone {
  POSITIVE
  MIXED
  NEEDS_WORK
}
