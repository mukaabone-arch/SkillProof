# Database (matches docker-compose)
DATABASE_URL="postgresql://skillproof:localdev@localhost:5432/skillproof"
# Auth
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="15m"
# OAuth (Google/GitHub sign-in — see docs/oauth-setup.md for console config)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# App
PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV=development
# Resume upload storage — local disk, ephemeral on Render unless a
# persistent Disk is attached and mounted at this path.
UPLOAD_DIR="./uploads"
# Email (application confirmations, status updates)
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
# Assessment integrity tuning (optional — sane defaults if unset)
INTEGRITY_FLAG_THRESHOLD=5
RAPID_ANSWER_THRESHOLD_MS=3000
# Gate applying on having a verified badge (optional, defaults false)
REQUIRE_VERIFIED_BADGE_TO_APPLY=false
ANTHROPIC_API_KEY=""
# Integrations (fill in when you reach each one — not read by any code yet;
# phone OTP send is also unimplemented in production, see auth.service.ts)
MSG91_AUTH_KEY=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
JUDGE0_API_KEY=""
